{
  "name": "Colorful_Theme",
  "colors": {
    "editor.background": "#0f0101",
    "editor.foreground": "#11faeaa6",

    // --- File Explorer & Sidebar ---
    "sideBar.foreground": "#11faeaa6", // Standard file and folder names
    "list.hoverBackground": "#ff029a15", // Background highlight when hovering over a file (Transparent Pink)

    "list.hoverForeground": "#7c1e2e", // File name color when you hover over it
    "list.activeSelectionForeground": "#02ff0a", // File name color of the file you are currently clicking

    // --- Git Status File Colors (Modified/New files) ---
    "gitDecoration.modifiedResourceForeground": "#9406fa", // Color of changed files (Yellow/Orange)
    "gitDecoration.untrackedResourceForeground": "#73ff00", // Color of brand new files (Green)
    "gitDecoration.ignoredResourceForeground": "#5a04f8", // Color of files in your .gitignore (Purple)

    // --- Editor Tabs (Top of the screen) ---
    "tab.activeForeground": "#11faea", // File name of your currently open tab
    "tab.inactiveForeground": "#01fbde5a",

    // --- Top Title Bar (Navbar) ---
    "titleBar.activeBackground": "#0f0101", // Background when focusing on VS Code
    "titleBar.activeForeground": "#11faeaa6", // Text & main menu color ("File", "Edit", etc.)
    "titleBar.inactiveBackground": "#050000", // Background when clicking away to another app
    "titleBar.inactiveForeground": "#09fce05a", // Text color when window is inactive
    "titleBar.border": "#11faeaa6", // Optional bottom border line for the navbar

    // --- Dropdown Menus (File, Edit, Selection dropdowns) ---
    "menu.background": "#0f0101", // Background of the opened dropdown menu box
    "menu.foreground": "#11faeaa6", // Text color inside the menu box
    "menu.selectionBackground": "#11faeaa6", // Background color when hovering over an item
    "menu.selectionForeground": "#0f0101", // Text color of the item you hover over
    // --- Side Bar Background & Layout ---
    "sideBar.background": "#0f0101", // Main background of the file tree
    "sideBar.border": "#11faeaa6", // Line separating sidebar from code editor
    "sideBarSectionHeader.background": "#050000", // Background of headers

    // --- Bottom Status Bar ---
    "statusBar.background": "#ee55d459", // Main background color of the status bar
    "statusBar.foreground": "#11faeaa6", // Text color for info (like Ln 162, Col 24, UTF-8)
    "statusBar.debuggingBackground": "#11faeaa6", // Background color when running or debugging code
    "statusBar.debuggingForeground": "#0f0b01", // Text color when debugging code
    "statusBar.noFolderBackground": "#050000", // Background color when you don't have a folder open
    "statusBar.border": "#11faeaa6", // Optional top border line to separate it from the editor

    // --- Diagnostic Squiggly Underlines ---
    "editorError.foreground": "#ff0000", // Underline color for critical code errors (Hot Pink)
    "editorWarning.foreground": "#fad506", // Underline color for basic warnings (Vibrant Orange)
    "editorInfo.foreground": "#b811fa", // Underline color for helpful hints/info (Cyan)
    "editorHint.foreground": "#60f40f", // Underline color for spell checks and code hints (Neon Green)

    // --- Bracket Pair Colorization ---
    "editorBracketHighlight.foreground1": "#11faea", // Outermost brackets (Layer 1)
    "editorBracketHighlight.foreground2": "#ff029a", // Second inner brackets (Layer 2)
    "editorBracketHighlight.foreground3": "#60f40f", // Third inner brackets (Layer 3)
    "editorBracketHighlight.foreground4": "#f606fa", // Fourth layer
    "editorBracketHighlight.foreground5": "#cb02f8", // Fifth layer
    "editorBracketHighlight.foreground6": "#068fff", // Sixth layer
    "editorBracketHighlight.unexpectedBracket.foreground": "#f44747", // Broken/mismatched brackets
    // --- Copy / Action Flash ---
    "editor.lineHighlightBackground": "#ff029a15", // The temporary flash when copying a line

    // --- Text Selection Highlight (Dragging mouse) ---
    "editor.selectionBackground": "#ff029a43", // Highlighting color when selecting text
    "editor.selectionHighlightBackground": "#04f3dfd3" // Highlights matching words elsewhere on screen
  },
  "tokenColors": [
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#000080"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#09fce05a"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#b6fd04"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.other.color.rgb-value",
        "constant.other.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#60f40f"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#ff029a"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#068fff"
      }
    },
    {
      "scope": "entity.name.tag.css",
      "settings": {
        "foreground": "#0553fa"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#bc87fa"
      }
    },
    {
      "scope": [
        "source.css entity.other.attribute-name",
        "source.css.less entity.other.attribute-name.id",
        "source.scss entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c07dd7"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#6796e6"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#068bf9"
      }
    },
    {
      "scope": "meta.selector",
      "settings": {
        "foreground": "#abd77d"
      }
    },
    {
      "name": "brackets of XML/HTML tags",
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#ec0c0c8f"
      }
    },
    {
      "scope": "meta.preprocessor",
      "settings": {
        "foreground": "#96d656"
      }
    },
    {
      "scope": "meta.preprocessor.string",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": "meta.preprocessor.numeric",
      "settings": {
        "foreground": "#b11096"
      }
    },
    {
      "scope": "meta.structure.dictionary.key.python",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#71befd"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#06febc"
      }
    },
    {
      "scope": "storage.modifier",
      "settings": {
        "foreground": "#0b73c9"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#cb02f8a4"
      }
    },
    {
      "scope": "string.tag",
      "settings": {
        "foreground": "#5a04f8"
      }
    },
    {
      "scope": "string.value",
      "settings": {
        "foreground": "#d74004"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#fab106"
      }
    },
    {
      "name": "JavaScript string interpolation ${}",
      "scope": [
        "punctuation.definition.template-expression.begin.js",
        "punctuation.definition.template-expression.begin.ts",
        "punctuation.definition.template-expression.end.ts",
        "punctuation.definition.template-expression.end.js"
      ],
      "settings": {
        "foreground": "#0588f3"
      }
    },
    {
      "scope": [
        "support.type.vendored.property-name",
        "support.type.property-name",
        "variable.css",
        "variable.scss",
        "variable.other.less"
      ],
      "settings": {
        "foreground": "#e502fe"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#028dff"
      }
    },
    {
      "scope": "keyword.control",
      "settings": {
        "foreground": "#01477c"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#2cfa03"
      }
    },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#d67056"
      }
    },
    {
      "scope": "keyword.other.unit",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "support.function.git-rebase",
      "settings": {
        "foreground": "#f97272"
      }
    },
    {
      "scope": "constant.sha.git-rebase",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "name": "coloring of the Java import and package identifiers",
      "scope": [
        "storage.modifier.import.java",
        "variable.language.wildcard.java",
        "storage.modifier.package.java"
      ],
      "settings": {
        "foreground": "#8d5959"
      }
    },
    {
      "name": "coloring of the TS this",
      "scope": "variable.language.this",
      "settings": {
        "foreground": "#7fd656"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars"
      ],
      "settings": {
        "foreground": "#ff4907"
      }
    },
    {
      "name": "Types declaration and references",
      "scope": [
        "meta.return-type",
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "source.cs storage.type"
      ],
      "settings": {
        "foreground": "#c6a42a"
      }
    },
    {
      "name": "Types declaration and references, TS grammar specific",
      "scope": [
        "meta.type.cast.expr",
        "meta.type.new.expr",
        "support.constant.math",
        "support.constant.dom",
        "support.constant.json",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "Control flow keywords",
      "scope": "keyword.control",
      "settings": {
        "foreground": "#c109b2"
      }
    },
    {
      "name": "Variable and parameter name",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9be16f"
      }
    },
    {
      "name": "Object keys, TS grammar specific",
      "scope": [
        "meta.object-literal.key",
        "meta.object-literal.key entity.name.function"
      ],
      "settings": {
        "foreground": "#02fb97"
      }
    },
    {
      "name": "CSS property value",
      "scope": [
        "support.constant.property-value",
        "support.constant.font-name",
        "support.constant.media-type",
        "support.constant.media",
        "constant.other.color.rgb-value",
        "constant.other.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#04fce7"
      }
    },
    {
      "name": "Framework Component Tags (Link, Image, etc.)",
      "scope": [
        "support.class.component.js",
        "support.class.component.tsx",
        "entity.name.tag.tsx",
        "entity.name.tag.js"
      ],
      "settings": {
        "foreground": "#fd5bbc"
      }
    }
  ]
}
